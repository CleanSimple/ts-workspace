{
    "name": "universal-media-shortcuts",
    "version": "0.26.2",
    "packageManager": "yarn@4.6.0",
    "private": true,
    "type": "module",
    "displayName": "Universal Media Shortcuts",
    "description": "Adds custom shortcuts to all video players",
    "author": "Nour Nasser <nours02345@gmail.com>",
    "userscript": {
        "namespace": "https://github.com/CleanSimple",
        "match": [
            "*://*/*"
        ],
        "run-at": "document-start",
        "grant": [
            "GM_addStyle",
            "GM_getValue",
            "GM_setValue"
        ]
    },
    "scripts": {
        "build": "clean ./dist && ts-rollup -c",
        "dev": "ts-rollup -c -w",
        "lint": "eslint",
        "fmt": "dprint fmt ./src/**",
        "version": "yarn build && git add dist"
    },
    "dependencies": {
        "@cleansimple/plain-jsx": "workspace:^",
        "@cleansimple/utils-js": "workspace:^"
    },
    "devDependencies": {
        "@cleansimple/dprint-config": "workspace:^",
        "@cleansimple/eslint-config": "workspace:^",
        "@cleansimple/rollup-config": "workspace:^",
        "@cleansimple/typescript-config": "workspace:^",
        "@types/node": "^25.3.0",
        "@types/tampermonkey": "^5.0.4",
        "dprint": "0.50.2",
        "eslint": "9.39.1",
        "rollup": "4.52.4",
        "typescript": "5.9.3"
    }
}
