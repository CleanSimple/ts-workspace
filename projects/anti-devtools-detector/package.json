{
    "name": "anti-devtools-detector",
    "version": "0.1.3",
    "packageManager": "yarn@4.6.0",
    "private": true,
    "type": "module",
    "displayName": "Anti-DevTools Detector!",
    "description": "Stops those pesky dev tools detectors",
    "author": "Nour Nasser <nours02345@gmail.com>",
    "userscript": {
        "namespace": "https://github.com/CleanSimple",
        "match": [
            "*://*/*"
        ],
        "run-at": "document-start",
        "grant": [
            "none"
        ]
    },
    "scripts": {
        "build": "clean ./dist && ts-rollup -c",
        "dev": "ts-rollup -c -w",
        "lint": "eslint",
        "fmt": "dprint fmt ./src/**",
        "version": "yarn build && git add dist"
    },
    "devDependencies": {
        "@cleansimple/dprint-config": "workspace:^",
        "@cleansimple/eslint-config": "workspace:^",
        "@cleansimple/rollup-config": "workspace:^",
        "@cleansimple/typescript-config": "workspace:^",
        "@types/node": "^25.3.0",
        "@types/tampermonkey": "^5.0.5",
        "dprint": "0.50.2",
        "eslint": "9.39.1",
        "rollup": "4.52.4",
        "typescript": "5.9.3"
    }
}
